{{define "subject"}}You've been invited to join {{.OrgName}} on keelwave{{end}}

{{define "body"}}
<!doctype html>
<html>
  <head>
    <meta name="viewport" content="width=device-width" />
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
  </head>
  <body>
    <p>Hi,</p>
    <p>You've been invited to join <strong>{{.OrgName}}</strong> on keelwave as <strong>{{.Role}}</strong>.</p>
    <p><a href="{{.InviteURL}}">Accept invite</a></p>
    <p>This link expires in 7 days. If you didn't expect this invite, you can safely ignore this email.</p>
    <p>— The keelwave team<br><a href="https://keelwave.com">keelwave.com</a></p>
  </body>
</html>
{{end}}
